# Modèle de configuration — COPIER en `.env` puis remplir (le `.env` réel n'est jamais commité).
# En production, ces variables se mettent dans Netlify → Site configuration → Environment variables.

# --- Supabase (Tranche 2) ---
# Project Settings → API
SUPABASE_URL=
# Clé `service_role` (ou Secret key sb_secret_...) — SECRÈTE, serveur uniquement, bypass RLS
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (Tranche 4) ---
# platform.openai.com → API keys (sk-...)
OPENAI_API_KEY=
# Modèle de génération (sortie structurée json_schema). À ajuster selon le catalogue courant.
OPENAI_MODEL=gpt-4.1

# --- Resend (Tranche 4) ---
# resend.com → API Keys (re_...)
RESEND_API_KEY=
# Expéditeur sur le domaine vérifié. Format complet « Nom <adresse> » ou adresse seule.
# Ex. : MIRA <contact@mira-audit.fr>
RESEND_FROM=
# Optionnel : boîte qui reçoit les réponses des prospects (sinon → l'adresse RESEND_FROM).
# Ex. : moetez@polaria.ai
RESEND_REPLY_TO=
# Optionnel : email interne notifié si une génération échoue.
OPS_EMAIL=
# Optionnel : notification interne « Nouveau pré-diagnostic généré » à chaque livraison
# réussie (liste d'adresses séparées par des virgules). Absente/vide → aucune notification.
# ⚠️ En local/test, n'y mettre QUE sa propre adresse.
# Ex. : caroline@polaria.ai,moetez@polaria.ai
NOTIF_EMAILS=

# --- Diagnostic ---
# Token exigé par la function envcheck (header x-envcheck-token). Absente → envcheck répond 404.
ENVCHECK_TOKEN=
